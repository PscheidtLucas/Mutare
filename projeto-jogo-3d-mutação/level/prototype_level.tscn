[sub_resource type="Shader" id="Shader_i07hj"]
code = "// NOTE: Shader automatically converted from Godot Engine 4.4.1.stable's PanoramaSkyMaterial.

shader_type sky;

uniform sampler2D source_panorama : filter_linear, source_color, hint_default_black;
uniform float exposure : hint_range(0, 128) = 1.0;
uniform float scroll_speed = 0.01; // <-- 1. Adicione esta linha para controlar a velocidade

void sky() {
	// 2. Modifique as coordenadas antes de usá-las
	vec2 scrolling_coords = SKY_COORDS;
	scrolling_coords.x += TIME * scroll_speed;

	COLOR = texture(source_panorama, scrolling_coords).rgb * exposure;
}"

