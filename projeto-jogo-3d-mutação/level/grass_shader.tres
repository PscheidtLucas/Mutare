code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_toon, specular_schlick_ggx;

uniform sampler2D WindNoise;
uniform vec4 BaseColor : source_color = vec4(0.678431, 0.098039, 0.000000, 1.000000);
uniform vec4 ColorParameter : source_color = vec4(1.000000, 0.772549, 0.313726, 1.000000);



void vertex() {
// Input:5
	vec3 n_out5p0 = VERTEX;


// Input:12
	vec3 n_out12p0 = NODE_POSITION_WORLD;


// VectorDecompose:13
	float n_out13p0 = n_out12p0.x;
	float n_out13p1 = n_out12p0.y;
	float n_out13p2 = n_out12p0.z;


// VectorCompose:14
	float n_in14p1 = 0.00000;
	vec2 n_out14p0 = vec2(n_out13p0, n_in14p1);


// Input:11
	float n_out11p0 = TIME;


// VectorOp:15
	vec2 n_out15p0 = n_out14p0 + vec2(n_out11p0);


// UVFunc:10
	vec2 n_in10p1 = vec2(0.30000, 0.30000);
	vec2 n_out10p0 = n_out15p0 * n_in10p1 + UV;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(WindNoise, n_out10p0);


// Input:2
	vec2 n_out2p0 = UV;


// VectorDecompose:3
	float n_out3p0 = n_out2p0.x;
	float n_out3p1 = n_out2p0.y;


// FloatFunc:4
	float n_out4p0 = 1.0 - n_out3p1;


// VectorOp:9
	vec3 n_out9p0 = vec3(n_out8p0.xyz) * vec3(n_out4p0);


// VectorOp:16
	vec3 n_in16p1 = vec3(0.50000, 0.50000, 0.50000);
	vec3 n_out16p0 = n_out9p0 * n_in16p1;


// VectorOp:6
	vec3 n_out6p0 = n_out5p0 + n_out16p0;


// Output:0
	VERTEX = n_out6p0;


}

void fragment() {
// ColorParameter:8
	vec4 n_out8p0 = BaseColor;


// ColorParameter:9
	vec4 n_out9p0 = ColorParameter;


// Input:4
	vec2 n_out4p0 = UV;


// VectorDecompose:5
	float n_out5p0 = n_out4p0.x;
	float n_out5p1 = n_out4p0.y;


// FloatFunc:6
	float n_out6p0 = 1.0 - n_out5p1;


// Mix:7
	vec3 n_out7p0 = mix(vec3(n_out8p0.xyz), vec3(n_out9p0.xyz), vec3(n_out6p0));


// FloatConstant:3
	float n_out3p0 = 0.000000;


// VectorCompose:2
	float n_in2p0 = 0.00000;
	float n_in2p1 = 1.00000;
	float n_in2p2 = 0.00000;
	vec3 n_out2p0 = vec3(n_in2p0, n_in2p1, n_in2p2);


// Output:0
	ALBEDO = n_out7p0;
	ROUGHNESS = n_out3p0;
	NORMAL = n_out2p0;
	NORMAL_MAP = n_out2p0;


}
