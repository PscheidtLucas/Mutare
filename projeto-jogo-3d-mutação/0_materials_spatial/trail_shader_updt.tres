[gd_resource type="ShaderMaterial" load_steps=2 format=3 uid="uid://c71lns42bvf16"]

[sub_resource type="Shader" id="Shader_1yf1b"]
code = "shader_type spatial;

render_mode unshaded, cull_disabled, depth_draw_never;

/* ======================
   CONFIGURAÇÕES EXPORTADAS
   ====================== */

uniform vec4 trail_color : source_color = vec4(1.0, 0.1, 0.0, 1.0);

uniform int blend_mode : hint_enum(\"Add\", \"Alpha\", \"SoftAdd\", \"Multiply\") = 0;

uniform float trail_length : hint_range(0.1, 4.0) = 1.4;
uniform float trail_width  : hint_range(0.01, 2.0) = 0.28;

uniform float fade_power : hint_range(0.1, 8.0) = 1.4;


/* ======================
   VÉRTICES
   ====================== */

void vertex() {
	VERTEX.z *= trail_length;
	VERTEX.x *= trail_width;
}


/* ======================
   FRAGMENTO
   ====================== */

void fragment() {
	float v = UV.y;
	float u = UV.x;

	float fade = pow(clamp(1.0 - v, 0.0, 1.0), fade_power);
	float edge = smoothstep(0.0, 0.01, 1.0 - abs(u * 2.0 - 1.0));

	vec3 base = trail_color.rgb;
	float alpha = trail_color.a * fade * edge;

	/* BLEND CUSTOMIZADO */
	vec3 final_color = vec3(0.0);
	float final_alpha = alpha;

	if (blend_mode == 0) {
		// ADD (padrão)
		final_color = base;
	}
	else if (blend_mode == 1) {
		// ALPHA BLEND
		final_color = base;
		final_alpha = alpha;
	}
	else if (blend_mode == 2) {
		// SOFT ADD (aditivo mais suave)
		final_color = base * 0.5;
	}
	else if (blend_mode == 3) {
		// MULTIPLY — funciona muito bem em fundos claros
		final_color = base * fade;
	}

	ALBEDO = final_color;
	ALPHA = final_alpha;

	EMISSION = final_color * fade;
}
"

[resource]
render_priority = 0
shader = SubResource("Shader_1yf1b")
shader_parameter/trail_color = Color(0, 0, 0, 1)
shader_parameter/blend_mode = 3
shader_parameter/trail_length = 1.4
shader_parameter/trail_width = 0.79100003687398
shader_parameter/fade_power = 4.83500022640262
